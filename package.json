{
  "name": "@secure-ai-app/cli",
  "version": "0.1.0",
  "description": "Security guardrails for AI-built applications",
  "license": "MIT",
  "type": "module",
  "bin": {
    "secure-ai-app": "dist/bin/secure-ai-app.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.3",
    "picocolors": "^1.1.1",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
